# ============================================================================
# Astraeus — environment configuration
# Copy this file to .env and fill in your keys. NEVER commit .env (it's gitignored).
# .env and this file share the SAME variables; this file just has blank secrets.
# ============================================================================

# ---- Required: model + data ----
# OpenRouter — LLM reasoning & forecasts (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
# CoinMarketCap AI Agent Hub — market data + Skill Hub (https://coinmarketcap.com/api/agent)
COINMARKETCAP_API_KEY=

# ---- Security ----
# Salt used by ElizaOS to encrypt secrets it persists in its database (character
# settings.secrets and any runtime-saved secrets). If unset it falls back to the
# hardcoded default "secretsalt" — i.e. a publicly known key — and core warns at boot.
# Set a strong, unique value BEFORE any secrets are stored (changing it later makes
# already-encrypted secrets undecryptable). Generate one with:
#   bun -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRET_SALT=

# Model selection is NOT configured here — it lives entirely in src/character.ts
# (settings.model / embeddingModel / the OPENROUTER_*_MODEL keys / settings.models).
# Edit the model IDs there; no env vars are involved.

# ---- Autonomous trading loop ----
# What to do on boot — space-separated flags (case-insensitive):
#   trade  → AUTO-START the autonomous loop + Track-1 heartbeat on boot, and resume the
#            cadence after a restart (also accepts auto/on/true). REQUIRED for the live
#            week; leave blank to keep the loop off and drive it from chat ("start auto").
#   cmc    → fold CMC options-positioning analysis (Skill Hub "source 7") into every loop
#            forecast — forces it on even if CMC_OPTIONS_ENRICH=false, at the cost of the
#            slow MCP call's latency. (With CMC_OPTIONS_ENRICH=true it's already on.)
# Example: AUTONOMOUS_MODE=trade cmc
AUTONOMOUS_MODE=
# Symbols to trade (comma-separated; must be on the eligible BEP-20 allowlist).
TRADING_SYMBOLS=ETH, USDT
# Timeframe for each autonomous trade: hourly | 4h | daily | weekly. Each position
# auto-closes after its timeframe (hourly→1h, 4h→4h, daily→24h, weekly→7d).
AUTONOMOUS_TIMEFRAME=daily
# Milliseconds between autonomous ticks on the happy path (43200000 = 12 hours).
AUTONOMOUS_INTERVAL_MS=43200000
# On an UNSUCCESSFUL auto-trade (ETH not forecast UP with conviction >= RISK_MIN_CONVICTION),
# retry on a shorter timeframe after this delay (3600000 = 1 hour): daily→4h→1h→1h…
# until a trade opens, then reset to the 12h base cadence. Unsuccessful attempts don't count.
AUTONOMOUS_RETRY_MS=3600000
# Paper-trading starting cash in USD (PAPER MODE ONLY — fake money, not real funds).
PAPER_START_CASH_USD=15

# ---- Track 1 trade heartbeat (competition daily-trade guarantee) ----
# A STANDALONE guarantee that runs INDEPENDENTLY of the trading loop: every
# TRACK1_QUALIFY_INTERVAL_MS (18h) the agent buys the TRACK1_QUALIFY_TRADE_USD size of ETH
# ($1.5) and immediately sells it back to USDT — a round-trip that registers a competition
# trade with ~zero market exposure (cost = fees + slippage). On success the next one is
# one interval later; if a round-trip FAILS it retries every TRACK1_QUALIFY_RETRY_MS until
# it lands. It never collides with the trading loop — if a loop cycle is running it waits
# for that to finish (success or no-position) first. OFF by default; turn ON for live week.
TRACK1_QUALIFY_ENABLED=true
# Cadence of the guaranteed qualifying round-trip (64800000 = 18 hours). Change this to
# tune how often the heartbeat trade fires.
TRACK1_QUALIFY_INTERVAL_MS=64800000
# USD size of the qualifying round-trip — INDEPENDENT of the main loop's RISK_MAX_TRADE_USD.
# Kept small ($1.5) so the daily-trade guarantee costs only fees + slippage, not real size.
TRACK1_QUALIFY_TRADE_USD=1.5
# If a qualifying round-trip FAILS (no price / swap error / insufficient cash), retry it
# this often (300000 = 5 minutes) until it lands.
TRACK1_QUALIFY_RETRY_MS=300000
# Block manual "forecast and trade BTC/BNB" in LIVE mode (true = block, default). BTC and
# BNB aren't on the competition's eligible token list, so a real buy wastes USDT on
# something that won't count (and may not route on TWAK). ETH is always allowed, and the
# autonomous loop only trades ETH. Set false to allow live BTC/BNB; paper mode is never blocked.
TRACK1_BLOCK_BTC_BNB=true

# ---- Risk guardrails (optional; defaults shown) ----
RISK_MAX_DRAWDOWN_PCT=10
RISK_MAX_TRADE_USD=5
RISK_MAX_TRADES_PER_DAY=2
RISK_MAX_DAILY_VOLUME_USD=10
RISK_MIN_TRADES_PER_DAY=2
RISK_MAX_SLIPPAGE_BPS=100
RISK_MIN_CONVICTION=60
RISK_MIN_CASH_RESERVE_PCT=0
# When CLOSING a position, sell this much LESS than the held amount (basis points,
# 50 = 0.5%) so a price tick / fee / rounding between the balance read and the swap can
# never request more than the wallet holds (a live TWAK swap rejects an over-balance
# amount, which would leave the position stuck open). Leaves negligible dust.
CLOSE_SELL_HAIRCUT_BPS=50

# ---- Take-profit (the OPPOSITE of the drawdown cap) ----
# Close a position EARLY once its unrealized gain reaches RISK_TAKE_PROFIT_PCT %, locking
# in the profit instead of waiting out the timeframe. The monitor checks open positions
# every RISK_TAKE_PROFIT_CHECK_MS while the loop runs. Toggle with RISK_TAKE_PROFIT_ENABLED
# (code default is OFF; set true to use it).
RISK_TAKE_PROFIT_ENABLED=true
RISK_TAKE_PROFIT_PCT=10
RISK_TAKE_PROFIT_CHECK_MS=14400000

# ---- Live trading on BNB Chain (Track 1 — NOT active until Trust Wallet Agent Kit is wired) ----
# Master switch for real on-chain trading. Keep false until tested in paper mode.
ENABLE_LIVE_TRADING=true
# BNB Smart Chain RPC + chain id (56 = BSC mainnet).
BSC_RPC_URL=https://bsc-dataseed.binance.org
CHAIN_ID=56
# Trust Wallet Agent Kit credentials (from portal.trustwallet.com).
TWAK_ACCESS_ID=
TWAK_HMAC_SECRET=
# Wallet password for HEADLESS / Docker signing ONLY (server, container, CI/CD).
# TWAK reads it here when there's no OS keychain. Resolution order: --password flag >
# TWAK_WALLET_PASSWORD > OS keychain. On your laptop, leave this BLANK and instead run
# `twak wallet keychain save`. NEVER commit a real value — use a Docker secret in prod.
TWAK_WALLET_PASSWORD=
# Retry a swap up to this many times on TRANSIENT errors only (TWAK price-service blips /
# NETWORK_ERROR / "unable to fetch price") — real reverts, auth, and insufficient-funds are
# NEVER retried. TWAK_SWAP_RETRY_MS is the spacing between attempts (ms).
TWAK_SWAP_RETRIES=10
TWAK_SWAP_RETRY_MS=2000
# Your agent's BSC wallet address (used for on-chain competition registration).
AGENT_WALLET_ADDRESS=
# BNB Hack Track 1 competition contract.
COMPETITION_CONTRACT_ADDRESS=0x212c61b9b72c95d95bf29cf032f5e5635629aed5
# Max auto-approved x402 payment per request, in atomic units (10000 = 0.011 USDC at 6dp).
X402_MAX_PAYMENT=11000
# Chain to settle x402 payments on (default "base"). CMC's x402 endpoints advertise
# their PREFERRED route as a stablecoin on BSC priced in 18 decimals (0.01 = 1e16 atomic),
# which exceeds the 6-dp X402_MAX_PAYMENT cap (PAYMENT_AMOUNT_EXCEEDED). Pinning to Base
# uses the 10000-atomic USDC (6dp) route — within the cap and the chain the wallet holds
# USDC on. Set to "bsc" or a CAIP id (e.g. eip155:8453) to override, or "" to let TWAK pick.
X402_PREFER_NETWORK=base
# Optional: pay an x402-gated endpoint each trade cycle to enrich the forecast.
# OFF by default. Best-effort: bounded by X402_ENRICH_TIMEOUT_MS and falls back to
# the free data path on any failure — it can never block or delay a trade beyond the timeout.
X402_ENRICH=true
# CMC AI Agent Hub x402 endpoints — COMMA-SEPARATED, each $0.01 USDC on Base per call,
# fetched in parallel and merged into the forecast. Flip X402_ENRICH=true once the
# TWAK wallet holds a little USDC on Base. Add/remove from these CMC x402 paths:
#   /x402/v3/cryptocurrency/quotes/latest?symbol=ETH   (ETH quote)
#   /x402/v3/cryptocurrency/listings/latest            (top-market regime context)
#   /x402/v4/dex/pairs/quotes/latest                   (DEX pair quotes)
#   /x402/v1/dex/search?q=eth                          (DEX search)
X402_DATA_URL=https://pro-api.coinmarketcap.com/x402/v3/cryptocurrency/quotes/latest?symbol=ETH,https://pro-api.coinmarketcap.com/x402/v1/dex/search?q=eth
X402_ENRICH_TIMEOUT_MS=25000

# ---- CMC AI Agent Hub forecast enrichment (supplementary ~40%; options data stays ~60%) ----
# CMC technicals (RSI/MACD/EMA) + market regime (total cap, BTC dominance) + Fear & Greed
# + current CMC price, fed into the ETH forecast. ON by default; set false to disable.
# Bounded + best-effort: a slow/failed CMC call is skipped and the forecast falls back to options.
CMC_ENRICH=true
CMC_ENRICH_TIMEOUT_MS=12000
# CMC options-positioning analysis (Skill Hub MCP) as forecast "source 7" in the loop.
# ON by default; bounded so the slow MCP call can NEVER stall the loop.
CMC_OPTIONS_ENRICH=true
CMC_OPTIONS_TIMEOUT_MS=150000
# Include source 7 (CMC options-positioning) in the MARKET overview's 30% options leg.
# OFF by default — it adds ~CMC_OPTIONS_TIMEOUT_MS of latency (slow MCP). Set true to enable.
MARKET_OPTIONS_ENRICH=true
# Per-asset forecast LLM call (OpenRouter) — retry on TRANSIENT failures only: network
# blips ("Unable to connect" / socket resets) and 408/429/5xx. Auth/400/other 4xx fail
# fast (no retry). FORECAST_LLM_RETRIES = total attempts; FORECAST_LLM_RETRY_MS = backoff
# (grows per attempt: 1×, 2×, 3×…). Defaults 3 / 1500ms.
FORECAST_LLM_RETRIES=3
FORECAST_LLM_RETRY_MS=1500
# ---- CMC skill bundles (qualitative Skill Hub analyses — SLOW, off by default) ----
# Master toggle for the per-feature CMC skill bundles added to MARKET overview / TRENDING /
# RESEARCH. OFF by default — each runs many slow execute_skill calls (~tens of sec each).
# Override the lists with MARKET_SKILLS / TRENDING_SKILLS / RESEARCH_SKILLS (comma-separated
# skill unique_names); leave blank to use the built-in defaults.
CMC_SKILLS_ENABLED=true
CMC_SKILLS_TIMEOUT_MS=100000
# Show the raw "CMC SKILL ANALYSES" bundle dump in MARKET / RESEARCH / TRENDING replies when
# the LLM can't synthesize it into a one-line read. OFF by default — the raw dump is noisy
# (e.g. "exchange_market_structure_monitor:BTC: …venue_concentration"); the synthesized "CMC
# skill read" line is the intended signal, and the bundle still feeds the score either way.
# Set true to restore the dump. LIQUIDATION/PORTFOLIO are unaffected (the bundle IS their output).
CMC_SKILLS_SHOW_RAW=false
# How much the CMC skill bundle MOVES the "overall market status" score (0–0.5; default 0.2
# = 20%). The LLM distills the bundle into a sentiment (-1..1) that's blended into the
# BULLISH/BEARISH number; the rest stays options + CMC REST. 0 = skills are shown but don't
# move the score. Only applies when CMC_SKILLS_ENABLED=true (research/trending just show the
# synthesized verdict — no score to move).
MARKET_SKILL_WEIGHT=0.2
# Agent debug report (chat: "debug skill bundles" / "debug research skills"). When the
# report LIVE-probes a bundle it runs at most this many skills per bundle (spends CMC
# credits). Say "debug all skill bundles" to probe every skill instead. Default 3.
DEBUG_SKILL_PROBE_LIMIT=3

# ---- BNB AI Agent SDK extras (optional, prize features) ----
# ERC-8004 on-chain agent identity command (AGENT_IDENTITY). Set false to disable it.
ERC8004_IDENTITY_ENABLED=true
# ERC-8183 sidecar bridge: when true, the agent publishes each forecast to
# data/latest-forecast.json so the optional Python sidecar can sell it as an on-chain
# job. OFF by default — turn on only when running the sidecar (see sidecar/README.md).
ERC8183_SIDECAR_ENABLED=true

# ---- Local database (optional) ----
# ElizaOS uses a local PGlite DB by default. Uncomment to override its location,
# or set POSTGRES_URL to use Postgres instead. NOTE: a custom PGLITE_DATA_DIR with a
# Windows backslash path can be mangled by dotenv and break DB writes (e.g. the
# central_messages insert failing, which silently drops the agent's reply) — use a
# forward-slash path, e.g. C:/Users/you/astraeus/.eliza/.elizadb
# PGLITE_DATA_DIR=
# POSTGRES_URL=

# ---- Logging (optional) ----
# LOG_LEVEL=info