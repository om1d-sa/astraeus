# ============================================================================
# Astraeus ERC-8183 sidecar — LOCAL env (gitignored; never commit this file)
# This wallet is SEPARATE from the TWAK trading wallet and must NEVER hold
# trading capital.
#
# YOU MUST FILL: WALLET_PASSWORD  (everything else has a safe default)
# ============================================================================

# --- FILL THIS (required) ---
# Password that encrypts the sidecar keystore at ~/.bnbagent/wallets/. Save it in
# a password manager — losing it means losing access to this wallet.
WALLET_PASSWORD=tcQjWEZLNR:PzF6

# --- Optional ---
# Leave blank to auto-generate a fresh sidecar key on first run (recommended).
# Only set this if you want to import an existing key. NEVER use your trading key.
PRIVATE_KEY=

# Network: testnet is gas-free (MegaFuel) and safe to demo. Change to bsc-mainnet
# only if you want it on mainnet (then fund this wallet with a little BNB for gas).
NETWORK=bsc-testnet

# Custom RPC endpoint. Blank = use the SDK's default public RPC for NETWORK.
RPC_URL=

# Minimum acceptable job budget, in raw token units (1000000000000000000 = 1 token).
ERC8183_SERVICE_PRICE=1000000000000000000

# Public base URL of THIS sidecar incl. /erc8183 (only needed when deployed publicly,
# e.g. https://your-host:8183/erc8183). Blank is fine for local testing.
ERC8183_AGENT_URL=

# Path to the forecast file the trading agent writes (default works as-is).
ASTRAEUS_FORECAST_FILE=../data/latest-forecast.json
