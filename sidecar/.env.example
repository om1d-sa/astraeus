# ============================================================================
# Astraeus ERC-8183 sidecar — environment
# Copy to sidecar/.env. This wallet is SEPARATE from the TWAK trading wallet and
# must NEVER hold trading capital. NEVER commit sidecar/.env.
# ============================================================================

# Sidecar wallet. Leave PRIVATE_KEY blank to auto-generate a fresh key on first
# run (encrypted to ~/.bnbagent/wallets/). WALLET_PASSWORD is required.
PRIVATE_KEY=
WALLET_PASSWORD=

# Network: start on testnet (gas-free identity/registration via MegaFuel paymaster).
NETWORK=bsc-testnet
RPC_URL=

# Minimum acceptable job budget, in raw token units (1000000000000000000 = 1 token).
ERC8183_SERVICE_PRICE=1000000000000000000

# Public base URL of THIS sidecar including the /erc8183 path (for LocalStorage mode),
# e.g. https://your-host:8183/erc8183
ERC8183_AGENT_URL=

# Path to the forecast file the trading agent writes (default: ../data/latest-forecast.json).
ASTRAEUS_FORECAST_FILE=../data/latest-forecast.json
